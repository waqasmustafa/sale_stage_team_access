<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="team_admin" model="sale.stage.team">
        <field name="name">Admin</field>
        <field name="sequence">10</field>
        <field name="is_admin_team">True</field>
    </record>

    <record id="team_csr" model="sale.stage.team">
        <field name="name">CSR's Team</field>
        <field name="sequence">20</field>
        <field name="is_admin_team">False</field>
        <!--
            After installing, open this Team record and add the
            following stages under "Allowed Stages" (as per your
            screenshot):
            Received, Confirmed, On Hold, Payment Pending,
            Customer Cancelled, Cancelled, Duplicate, Not Answering,
            Critical Orders, Urgent Orders
        -->
    </record>

    <record id="team_store" model="sale.stage.team">
        <field name="name">Store Team</field>
        <field name="sequence">30</field>
        <field name="is_admin_team">False</field>
        <!--
            Add stages: Ready, Stock Awaiting
        -->
    </record>

    <record id="team_purchase" model="sale.stage.team">
        <field name="name">Purchase Team</field>
        <field name="sequence">40</field>
        <field name="is_admin_team">False</field>
        <!--
            Add stage: Stock Available
        -->
    </record>

    <record id="team_logistics" model="sale.stage.team">
        <field name="name">Logistics Team</field>
        <field name="sequence">50</field>
        <field name="is_admin_team">False</field>
        <!--
            Add stages: Packed, TBD, Return Received, Returns Initiated,
            Stock Punch, Load Sheet, Parcel Tracking, Dispatched, Delivered
        -->
    </record>

</odoo>
