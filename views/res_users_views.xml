<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_inherit_stage_team" model="ir.ui.view">
        <field name="name">res.users.form.inherit.stage.team</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Stage Access" name="stage_access">
                    <group>
                        <group string="Assigned Teams">
                            <field name="is_admin_stage_team"/>
                            <field name="is_csr_stage_team"/>
                            <field name="is_store_stage_team"/>
                            <field name="is_purchase_stage_team"/>
                            <field name="is_logistics_stage_team"/>
                        </group>
                    </group>
                    <div class="alert alert-warning" role="alert">
                        Select the Team(s) this user belongs to. This
                        determines which Sale Order stages the user is
                        allowed to move an order into. Users assigned to
                        the "Admin Stage Team" (or real Odoo System
                        Administrators) can move orders to any stage.
                    </div>
                </page>
            </notebook>
        </field>
    </record>

</odoo>
