<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add "Stage Access" tab on the Users form (Settings > Users) -->
    <record id="view_users_form_inherit_stage_team" model="ir.ui.view">
        <field name="name">res.users.form.inherit.stage.team</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Stage Access" name="stage_access">
                    <group>
                        <field name="team_ids" widget="many2many_checkboxes"/>
                    </group>
                    <div class="alert alert-warning" role="alert">
                        Select the Team(s) this user belongs to. This
                        determines which Sale Order stages the user is
                        allowed to move an order into. Users assigned to
                        the "Admin" team (or real Odoo System
                        Administrators) can move orders to any stage.
                    </div>
                </page>
            </notebook>
        </field>
    </record>

    <!-- Same tab on "My Profile" simplified preferences form -->
    <record id="view_users_preferences_form_inherit_stage_team" model="ir.ui.view">
        <field name="name">res.users.preferences.form.inherit.stage.team</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form_simple_modif"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Sale Stage Access"
                       invisible="not id">
                    <field name="team_ids" widget="many2many_checkboxes" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
