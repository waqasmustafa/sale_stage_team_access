<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_sale_stage_team_list" model="ir.ui.view">
        <field name="name">sale.stage.team.list</field>
        <field name="model">sale.stage.team</field>
        <field name="arch" type="xml">
            <list string="Sale Stage Teams">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="is_admin_team"/>
                <field name="user_count"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_sale_stage_team_form" model="ir.ui.view">
        <field name="name">sale.stage.team.form</field>
        <field name="model">sale.stage.team</field>
        <field name="arch" type="xml">
            <form string="Sale Stage Team">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. CSR's Team"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="is_admin_team"/>
                        </group>
                    </group>
                    <group string="Allowed Stages"
                           invisible="is_admin_team">
                        <field name="stage_ids" nolabel="1" widget="many2many_tags"
                               placeholder="Select the stages this team can move orders into..."/>
                    </group>
                    <div class="alert alert-info" role="alert"
                         invisible="not is_admin_team">
                        This team has Full Access. Members can move a Sale
                        Order to ANY stage, so an allowed-stage list is not
                        required.
                    </div>
                    <notebook>
                        <page string="Users">
                            <field name="user_ids" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_sale_stage_team" model="ir.actions.act_window">
        <field name="name">Sale Stage Teams</field>
        <field name="res_model">sale.stage.team</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Team and select which Sale Order stages it can move orders into
            </p>
        </field>
    </record>

    <!-- Menu: Sales > Configuration > Sale Stage Teams -->
    <menuitem id="menu_sale_stage_team"
              name="Sale Stage Teams"
              action="action_sale_stage_team"
              parent="sale.menu_sale_config"
              sequence="60"/>

</odoo>
