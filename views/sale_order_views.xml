<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_stage_team_access" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.stage.team.access</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <field name="allowed_stage_ids" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='stage_id']" position="attributes">
                <attribute name="domain">[('id', 'in', allowed_stage_ids)]</attribute>
            </xpath>
        </field>
    </record>
</odoo>
